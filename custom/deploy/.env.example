# 复制为 .env 并修改（务必改掉默认密码）
# cp .env.example .env

# 数据库 / Redis 密码（自己生成强密码）
PG_PASSWORD=change_me_pg_pwd
REDIS_PASSWORD=change_me_redis_pwd

# 会话密钥：必须改成随机串（否则重启后登录态失效；多实例必须一致）
# 生成：openssl rand -hex 32
SESSION_SECRET=change_me_random_64hex

# 对外端口（x2api 占 8080，这里默认 3000）
NEWAPI_PORT=3000

# 镜像：N1 用官方；接入自建代码后换成阿里云 ACR 地址，例如
# NEWAPI_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/new-api:custom
NEWAPI_IMAGE=calciumion/new-api:latest
